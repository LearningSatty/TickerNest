# TickerNest API config
# Copy this file to .env and fill in your values.

# ── Postgres (Supabase) ──────────────────────────────────────────────────────
#
# Supabase gives you TWO pooler URLs (Project Settings → Database → Connection string):
#
#  Transaction pooler (port 6543) — use this for DATABASE_URL here (the running API).
#    postgresql://postgres.[ref]:[pwd]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
#  Session pooler (port 5432) — use this for running migrations:
#    DATABASE_URL="postgresql://postgres.[ref]:[pwd]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres" \
#      npx ts-node src/scripts/migrate.ts
#
# Do NOT use the direct URL (db.[ref].supabase.co) — it requires IPv6 on new projects.
#
DATABASE_URL=postgresql://postgres.<project-ref>:<pwd>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=redis://default:<pwd>@<endpoint>.upstash.io:6379

# ── Supabase auth ────────────────────────────────────────────────────────────
# Project Settings → API → Project URL (e.g. https://abcdefg.supabase.co)
# Required for ES256 JWT verification (the JWKS endpoint lives under it).
SUPABASE_URL=https://<project-ref>.supabase.co

# Project Settings → API → JWT secret (only used for HS256 / legacy projects).
# Newer projects sign with ES256, in which case this can be left blank.
SUPABASE_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:5173

# ── Optional ─────────────────────────────────────────────────────────────────
PORT=3000
DB_POOL_MAX=10
DISABLE_PG_LISTENER=0
